NODE_ENV=production
PORT=3333

# PostgreSQL — Railway fornece automaticamente via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/hotel_pms?schema=public

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_32_CHARS_OU_MAIS
JWT_EXPIRES_IN=8h

BCRYPT_ROUNDS=12

# URL do frontend Vercel — sem barra no final
CORS_ORIGIN=https://seu-projeto.vercel.app

# NFS-e — 'mock' para testes, configure o provedor real para produção
NFSE_PROVIDER=mock
# NFSE_PROVIDER=nuvemfiscal
# NFSE_CLIENT_ID=
# NFSE_CLIENT_SECRET=
# NFSE_CNPJ=00000000000191
# NFSE_AMBIENTE=homologacao
